# Runtime environment: dev, test, or production
MN_ENV=dev

# Base application directory
MN_HOME=~/.mn

# Logging
MN_LOG_LEVEL=info
MN_LOG_MAX_BYTES=1048576
MN_LOG_BACKUP_COUNT=5
MN_CLI_LOG_PATH=~/.mn/logs/cli.log
MN_CLI_OUTPUT=rich

# Runtime connection
MN_GRPC_TARGET=localhost:55051
MN_GRPC_TIMEOUT_SECONDS=10

# API and web UI defaults
MN_API_HOST=127.0.0.1
MN_API_PORT=8000
MN_WEB_UI_HOST=127.0.0.1
MN_WEB_UI_PORT=5173

# Optional external services
MN_REDIS_URL=
MN_ALLOWED_ORIGINS=http://localhost:5173

# Optional secret placeholders. Prefer real environment variables in production.
MN_GRPC_AUTH_TOKEN=
MN_GRPC_ADMIN_TOKEN=
MN_LLM_API_KEY=
